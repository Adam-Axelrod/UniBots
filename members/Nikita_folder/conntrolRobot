from gpiozero import Servo
from pynput import keyboard
from time import sleep
import os

# If running on Windows to test logic, uncomment the line below:

# Setup pins
motor_turn = Servo(17) # A/D for Steering
motor_move = Servo(22) # W/S for Forward/Back

def stop_robot():
    motor_turn.value = 0
    motor_move.value = 0

def on_press(key):
    try:
        if key.char == 'w':
            print("Forward")
            motor_move.value = 1.0
        elif key.char == 's':
            print("Backward")
            motor_move.value = -1.0
        elif key.char == 'a':
            print("Left")
            motor_turn.value = -1.0
        elif key.char == 'd':
            print("Right")
            motor_turn.value = 1.0
    except AttributeError:
        pass

def on_release(key):
    # When you let go of a key, stop that specific action
    if key.char in ['w', 's']:
        motor_move.value = 0
    if key.char in ['a', 'd']:
        motor_turn.value = 0
    
    # Press ESC to exit the program
    if key == keyboard.Key.esc:
        stop_robot()
        return False

print("Control your robot with WASD (Press ESC to quit)")

# This starts the "listener" that watches the keyboard in the background
with keyboard.Listener(on_press=on_press, on_release=on_release) as listener:
    listener.join()