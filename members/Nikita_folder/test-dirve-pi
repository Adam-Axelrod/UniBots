from gpiozero import Robot
from time import sleep

# Define the pins for the Left motor (17, 27) and Right motor (22, 23)sud
robot = Robot(left=(17, 27), right=(22, 23))

def efficient_drive():
    print("Moving Forward...")
    robot.forward(speed=0.7) # 70% speed is often more efficient than 100%
    sleep(2)

    print("Curving Right...")
    # curve_right(0.5) means right wheel slowed by 50%
    robot.right(0.5) 
    sleep(1)

    print("Stopping...")
    robot.stop()

if __name__ == "__main__":
    try:
        efficient_drive()
    except KeyboardInterrupt:
        robot.stop()